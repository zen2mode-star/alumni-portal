generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String        @id @default(cuid())
  email            String        @unique
  password         String
  role             String        @default("STUDENT")
  status           String        @default("PENDING")
  name             String
  designation      String?
  bio              String?
  imageUrl         String?
  location         String?
  phone            String?
  website          String?
  branch           String?
  startYear        Int?
  gradYear         Int?
  rollNumber       String?
  hostel           String?
  higherStudies    String?
  company          String?
  jobRole          String?
  skills           String?
  achievements     String?
  linkedinUrl      String?
  githubUrl        String?
  twitterUrl       String?
  instagramUrl     String?
  canMentor        Boolean       @default(false)
  isSpotlight      Boolean       @default(false)
  spotlightBio     String?
  warningCount     Int           @default(0)
  isBlocked        Boolean       @default(false)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  authoredEvents   Event[]
  authoredJobs     Job[]
  jobInterests     JobInterest[]
  receivedMessages Message[]     @relation("ReceivedMessages")
  sentMessages     Message[]     @relation("SentMessages")
  posts            Post[]
  legacyPhotos     LegacyPhoto[]
  notifications    Notification[]
  appeals          Appeal[]
  blocksGiven      Block[]       @relation("BlocksGiven")
  blocksReceived   Block[]       @relation("BlocksReceived")
  strikesGiven     Strike[]      @relation("StrikesGiven")
  strikesReceived  Strike[]      @relation("StrikesReceived")
}

model Post {
  id        String   @id @default(cuid())
  content   String
  imageUrl  String?
  authorId  String
  roleSnap  String
  status    String   @default("APPROVED")
  adminEdited Boolean  @default(false)
  createdAt DateTime @default(now())
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  appeals   Appeal[]
}

model Message {
  id         String   @id @default(cuid())
  content    String?
  imageUrl   String?
  audioUrl   String?
  type       String   @default("TEXT") // TEXT, IMAGE, AUDIO
  senderId   String
  receiverId String
  read       Boolean  @default(false)
  deletedFor String   @default("")
  createdAt  DateTime @default(now())
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  sender     User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  message   String
  type      String   @default("INFO") // INFO, STRIKE, EDIT, ADMIN
  read      Boolean  @default(false)
  targetId  String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Appeal {
  id              String   @id @default(cuid())
  userId          String
  postId          String
  reason          String
  originalContent String?
  status          String   @default("PENDING") // PENDING, RESOLVED, REJECTED
  createdAt       DateTime @default(now())
  post            Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Block {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())
  blocked   User     @relation("BlocksReceived", fields: [blockedId], references: [id], onDelete: Cascade)
  blocker   User     @relation("BlocksGiven", fields: [blockerId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
}

model Strike {
  id        String   @id @default(cuid())
  strikerId String
  targetId  String
  reason    String?
  createdAt DateTime @default(now())
  striker   User     @relation("StrikesGiven", fields: [strikerId], references: [id], onDelete: Cascade)
  target    User     @relation("StrikesReceived", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([strikerId, targetId])
}

model Job {
  id          String        @id @default(cuid())
  title       String
  company     String
  description String
  link        String?
  images      JobImage[]
  authorId    String
  status      String        @default("PENDING")
  createdAt   DateTime      @default(now())
  author      User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  interests   JobInterest[]
}

model JobImage {
  id    String @id @default(cuid())
  url   String
  jobId String
  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model JobInterest {
  id        String   @id @default(cuid())
  userId    String
  jobId     String
  createdAt DateTime @default(now())
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
}

model Event {
  id          String   @id @default(cuid())
  title       String
  date        DateTime
  description String
  authorId    String
  status      String   @default("APPROVED")
  createdAt   DateTime @default(now())
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model VerifiedEmail {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      String   @default("ALUMNI") // ALUMNI or STAFF
  authCode  String?  @unique
  startYear Int?
  gradYear  Int?
  createdAt DateTime @default(now())
}

model HomeBanner {
  id        String   @id @default(cuid())
  imageUrl  String
  title     String?
  link      String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model HomeCompany {
  id        String   @id @default(cuid())
  name      String   @unique
  logoUrl   String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model Notice {
  id          String   @id @default(cuid())
  title       String
  content     String
  designation String   @default("Administration")
  priority    String   @default("NORMAL")
  createdAt   DateTime @default(now())
}

model SiteAsset {
  id        String   @id @default(cuid())
  key       String   @unique
  url       String
  updatedAt DateTime @updatedAt
}

model SiteConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model LegacyPhoto {
  id        String   @id @default(cuid())
  imageUrl  String
  caption   String?
  year      Int
  status    String   @default("PENDING")
  authorId  String
  createdAt DateTime @default(now())
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
}
